# semgrepignore / opengrepignore — paths excluded from SAST scanning.
# gitignore-style syntax; opengrep reads this file (fork of semgrep).

# Fluid templates. TYPO3 Fluid is HTML-ish but NOT Django/Jinja — the auto
# ruleset incorrectly loads Python/Django rules for .html files, producing
# false positives (e.g. django-no-csrf-token on <form> tags that are CSRF-
# protected by TYPO3's FormProtectionFactory, not Django middleware).
# There are no semgrep rules that understand Fluid, so excluding .html
# templates removes noise without losing real coverage.
Resources/Private/Templates/

# Build cache (never be in repo, belt-and-braces)
.Build/
Documentation-GENERATED-temp/
node_modules/
vendor/

# Functional test CSV fixtures contain synthetic argon2 / bcrypt hashes for
# test backend users. Opengrep's `generic.secrets.security.detected-bcrypt-hash`
# rule cannot distinguish test fixtures from real credentials. The `.gitleaks.toml`
# allowlist already covers these paths for the repo-level secret scanner.
Tests/Functional/**/be_users*.csv
Tests/Functional/**/Fixtures/**
Tests/Functional/Fixtures/**

# Synthetic secret-pattern fixtures for the secret-detection fuzz tests.
# Every literal below is deliberately crafted to look like a real credential
# so the detection service's pattern matcher can be exercised. The
# `detected-jwt-token` / `detected-bcrypt-hash` rules cannot distinguish
# test fixtures from real leaks.
Tests/Fuzz/OAuthFuzzTest.php
Tests/Fuzz/SecretDetectionFuzzTest.php
