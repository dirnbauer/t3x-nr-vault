#!/bin/bash

## Description: Install TYPO3 v14 with nr_vault extension
## Usage: install-v14
## Example: ddev install-v14

set -e

V14_DIR="/var/www/html/v14"
EXTENSION_DIR="/var/www/nr_vault"

echo "=== Installing TYPO3 v14 with nr_vault extension ==="

# Create v14 directory if it doesn't exist
if [ ! -d "$V14_DIR" ]; then
    mkdir -p "$V14_DIR"
fi

cd "$V14_DIR"

# Initialize composer project if not exists
if [ ! -f "composer.json" ]; then
    echo "Creating TYPO3 v14 project..."
    # Clean any leftover files
    rm -rf ./* ./.[!.]* 2>/dev/null || true

    # Create project in temp directory first (avoids volume mount issues)
    TEMP_DIR=$(mktemp -d)
    composer create-project typo3/cms-base-distribution:^14 "$TEMP_DIR" --no-interaction

    # Copy files to target (cp works better with volume mounts than mv)
    cp -a "$TEMP_DIR"/. "$V14_DIR"/
    rm -rf "$TEMP_DIR"
fi

# Set PHP platform to 8.5 (nr_vault requires PHP 8.5+)
echo "Configuring PHP platform..."
composer config platform.php 8.5.0

# Add local extension as path repository
echo "Configuring local extension repository..."
composer config repositories.nr_vault path "$EXTENSION_DIR" --no-interaction 2>/dev/null || true

# Require the extension (use @dev for local path)
echo "Requiring nr_vault extension..."
composer require netresearch/nr-vault:@dev --no-interaction

# Run TYPO3 setup if not already done
if [ ! -f "config/system/settings.php" ]; then
    echo "Running TYPO3 setup..."

    # Create database if not exists
    mysql -h db -u root -proot -e "CREATE DATABASE IF NOT EXISTS v14;" 2>/dev/null || true

    # Run setup
    vendor/bin/typo3 setup \
        --driver=mysqli \
        --host=db \
        --port=3306 \
        --dbname=v14 \
        --username=root \
        --password=root \
        --admin-username="${TYPO3_SETUP_ADMIN_USERNAME:-admin}" \
        --admin-email="${TYPO3_SETUP_ADMIN_EMAIL:-admin@example.com}" \
        --admin-user-password="${TYPO3_SETUP_ADMIN_PASSWORD:-Joh316!!}" \
        --project-name="${TYPO3_PROJECT_NAME:-EXT:nr_vault Dev Environment}" \
        --server-type="${TYPO3_SERVER_TYPE:-apache}" \
        --no-interaction \
        --force
fi

# Configure trusted hosts pattern for DDEV
echo "Configuring trusted hosts..."
sed -i "s/'sitename' => 'EXT:nr_vault Dev',/'sitename' => 'EXT:nr_vault Dev',\n        'trustedHostsPattern' => '.*\\\\.ddev\\\\.site',/" config/system/settings.php

# Set up all extensions (includes nr_vault)
echo "Setting up extensions..."
vendor/bin/typo3 extension:setup

# Clear caches
echo "Clearing caches..."
vendor/bin/typo3 cache:flush

echo ""
echo "=== TYPO3 v14 installation complete ==="
echo ""
echo "Access URLs:"
echo "  Landing page: https://${DDEV_SITENAME}.ddev.site/"
echo "  TYPO3 v14:    https://v14.${DDEV_SITENAME}.ddev.site/typo3/"
echo "  Documentation: https://docs.${DDEV_SITENAME}.ddev.site/"
echo ""
echo "Login credentials:"
echo "  Username: admin"
echo "  Password: Joh316!!"
echo ""
