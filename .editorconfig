# EditorConfig - https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,ts}]
indent_size = 2

[*.rst]
indent_size = 3

[*.sql]
indent_size = 4

[*.html]
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 4
shell_variant = bash

[{composer.json,package.json}]
indent_size = 4
