<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit config for Infection mutation runs.

  Infection's initial run needs to collect coverage across the Unit suite and
  is very sensitive to PHPUnit 12 "coverage target" warnings emitted for
  final/readonly classes. The main Build/phpunit.xml sets failOnWarning="true"
  which aborts the initial run before any mutants are generated.

  This variant disables failOnRisky/failOnWarning so coverage collection
  completes; the main suite (run standalone) keeps the strict flags.
-->
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd"
    backupGlobals="true"
    bootstrap="../Tests/bootstrap.php"
    cacheDirectory=".phpunit.cache"
    colors="true"
    displayDetailsOnPhpunitDeprecations="false"
    displayDetailsOnTestsThatTriggerDeprecations="false"
    displayDetailsOnTestsThatTriggerErrors="true"
    displayDetailsOnTestsThatTriggerNotices="false"
    displayDetailsOnTestsThatTriggerWarnings="false"
    failOnRisky="false"
    failOnWarning="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>../Tests/Unit</directory>
        </testsuite>
    </testsuites>

    <source ignoreSuppressionOfDeprecations="true">
        <include>
            <directory suffix=".php">../Classes</directory>
        </include>
        <exclude>
            <directory>../Classes/Exception</directory>
            <file>../Classes/Controller/AuditController.php</file>
            <file>../Classes/Controller/MigrationController.php</file>
            <file>../Classes/Controller/OverviewController.php</file>
            <file>../Classes/Controller/SecretsController.php</file>
            <file>../Classes/Form/Element/VaultSecretInputElement.php</file>
            <file>../Classes/Adapter/VaultAdapterInterface.php</file>
            <file>../Classes/Audit/AuditContextInterface.php</file>
            <file>../Classes/Audit/AuditLogServiceInterface.php</file>
            <file>../Classes/Configuration/ExtensionConfigurationInterface.php</file>
            <file>../Classes/Configuration/SiteConfigurationVaultProcessorInterface.php</file>
            <file>../Classes/Crypto/EncryptionServiceInterface.php</file>
            <file>../Classes/Crypto/MasterKeyProviderFactoryInterface.php</file>
            <file>../Classes/Crypto/MasterKeyProviderInterface.php</file>
            <file>../Classes/Domain/Repository/SecretRepositoryInterface.php</file>
            <file>../Classes/Http/VaultHttpClientInterface.php</file>
            <file>../Classes/Security/AccessControlServiceInterface.php</file>
            <file>../Classes/Service/SecretDetectionServiceInterface.php</file>
            <file>../Classes/Service/VaultServiceInterface.php</file>
            <file>../Classes/Service/Detection/SecretFinding.php</file>
            <file>../Classes/Http/SecretPlacement.php</file>
            <file>../Classes/Service/Detection/Severity.php</file>
            <file>../Classes/Service/VaultFieldPermission.php</file>
        </exclude>
    </source>

    <php>
        <ini name="display_errors" value="1"/>
        <ini name="error_reporting" value="-1"/>
        <env name="TYPO3_CONTEXT" value="Testing"/>
    </php>
</phpunit>
